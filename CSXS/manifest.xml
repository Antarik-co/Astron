<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  ExtensionBundleId="co.antarik.astron"
  ExtensionBundleVersion="1.0.1"
  Version="11.0">

  <ExtensionList>
    <Extension Id="co.antarik.astron.panel" Version="1.0.1"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[22.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="co.antarik.astron.panel">
      <DispatchInfo>

        <Resources>
          <MainPath>./dist/index.html</MainPath>
          <ScriptPath>./dist/extendscript/core.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--enable-nodejs</Parameter>
          </CEFCommandLine>
        </Resources>

        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>

        <UI>
          <Type>Panel</Type>
          <Menu>Astron</Menu>
          <Geometry>
            <Size>
              <Height>700</Height>
              <Width>280</Width>
            </Size>
            <MinSize>
              <Height>500</Height>
              <Width>240</Width>
            </MinSize>
            <MaxSize>
              <Height>1200</Height>
              <Width>400</Width>
            </MaxSize>
          </Geometry>
          <Icons/>
        </UI>

      </DispatchInfo>
    </Extension>
  </DispatchInfoList>

</ExtensionManifest>
