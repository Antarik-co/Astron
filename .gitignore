# ============================================================
# Astron — .gitignore
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
package-lock.json

# ── Build Output ─────────────────────────────────────────────
dist/
release/
*.zxp
*.zip

# ── 🔒 API Keys & Secrets (CRITICAL) ────────────────────────
# These files contain API keys and MUST NEVER be committed
src/config/api-keys.ts
src/config/api-keys.js
run-task.js
.env
.env.*
*.p12
tools/

# ── IDE & Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
ehthumbs.db
*.lnk

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── TypeScript Cache ─────────────────────────────────────────
*.tsbuildinfo

# ── Misc ─────────────────────────────────────────────────────
*.orig
*.bak
*.tmp
